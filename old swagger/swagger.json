{
  "openapi": "3.0.0",
  "info": {
    "title": "CloudAggregator Mock Operator Wallet",
    "description": "Mock Operator Wallet API for CloudAggregator integration testing.\nImplements the CloudAggregator Platform Integration Guide with full error code coverage.",
    "version": "1.0.0",
    "contact": {
      "name": "CloudAggregator",
      "url": "https://cloudaggregator.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local mock wallet server"
    }
  ],
  "paths": {
    "/cloudagg": {
      "get": {
        "summary": "CloudAggregator Transaction Callback Handler",
        "description": "Universal callback endpoint for all CloudAggregator transactions.\nDispatches to appropriate handler based on 'request' query parameter.\n\n**Authentication:** All requests must include valid X-CA-Signature header.",
        "operationId": "handleTransaction",
        "parameters": [
          {
            "name": "request",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "getaccount",
                "getbalance",
                "wager",
                "result",
                "wagerAndResult",
                "refund",
                "jackpot",
                "purchase"
              ]
            },
            "description": "Transaction request type",
            "example": "wager"
          },
          {
            "name": "session_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "maxLength": 36
            },
            "description": "Unique session ID generated by operator. Format {operator_id}_{uuid}",
            "example": "CA_OP_42_demo-session-001"
          },
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "maxLength": 32
            },
            "description": "Operator's unique player identifier",
            "example": "PLR_78345"
          },
          {
            "name": "device",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["desktop", "mobile", "tablet"]
            },
            "description": "Player's device type",
            "example": "desktop"
          },
          {
            "name": "game_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "CloudAggregator game ID",
            "example": "50301"
          },
          {
            "name": "transaction_id",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 255
            },
            "description": "Unique transaction identifier (idempotency key)",
            "example": "TXN_WAGER_001"
          },
          {
            "name": "round_id",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 255
            },
            "description": "Game round identifier",
            "example": "RND_001"
          },
          {
            "name": "bet_amount",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Wager amount in major currency units",
            "example": 5.00
          },
          {
            "name": "win_amount",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Win amount in major currency units",
            "example": 12.50
          },
          {
            "name": "game_status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["pending", "completed"]
            },
            "description": "Game round status",
            "example": "completed"
          },
          {
            "name": "jackpot_amount",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Jackpot prize amount",
            "example": 10000.00
          },
          {
            "name": "purchase_amount",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Purchase/feature buy amount",
            "example": 1.50
          },
          {
            "name": "api_version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API version",
            "example": "2.0"
          }
        ],
        "headers": {
          "X-CA-Signature": {
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "HMAC-SHA256 signature of request body (empty string for GET).\nFormat: hex(HMAC_SHA256(body, shared_secret))",
            "example": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
          }
        },
        "responses": {
          "200": {
            "description": "Success (business logic response in body)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "status": {
                      "type": "string",
                      "example": "Success"
                    },
                    "message": {
                      "type": "string"
                    },
                    "balance": {
                      "type": "number",
                      "example": 307.50
                    },
                    "real_balance": {
                      "type": "number",
                      "example": 257.50
                    },
                    "bonus_balance": {
                      "type": "number",
                      "example": 50.00
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized (invalid signature)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 401
                    },
                    "status": {
                      "type": "string",
                      "example": "Unauthorized"
                    },
                    "message": {
                      "type": "string",
                      "example": "Invalid signature"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Simple health check endpoint",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "HMACSignature": {
        "type": "apiKey",
        "in": "header",
        "name": "X-CA-Signature",
        "description": "HMAC-SHA256 signature of the request body.\nFor GET requests, sign empty string.\nFormat: hex(HMAC_SHA256(\"\", shared_secret))"
      }
    }
  },
  "security": [
    {
      "HMACSignature": []
    }
  ],
  "tags": [
    {
      "name": "Transactions",
      "description": "Transaction callback endpoints"
    },
    {
      "name": "Health",
      "description": "Service health check"
    }
  ]
}
