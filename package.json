{
  "name": "test-cas-wal",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/ishaan-puniani/test-cas-wal#readme",
  "bugs": {
    "url": "https://github.com/ishaan-puniani/test-cas-wal/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishaan-puniani/test-cas-wal.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "mongoose": "^9.3.3",
    "swagger-ui-express": "^5.0.0",
    "yaml": "^2.3.4"
  },
  "scripts": {
    "start": "node index.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "test:flow": "bash scripts/flow-test.sh",
    "test:flow:advanced": "bash scripts/flow-test-advanced.sh",
    "test:flows": "echo 'Running basic flow...' && bash scripts/flow-test.sh && echo '' && echo 'Running advanced flow...' && bash scripts/flow-test-advanced.sh"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["./tests/setup.js"],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "index.js",
      "!src/repository/WalletRepository.js"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 70,
        "statements": 80
      }
    }
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
